<?xml version="1.0" encoding="utf-8"?>
<!--
    Google Play Services Font Provider certificates.
    Used by Compose downloadable-fonts to verify the font provider.
    These are public, published by Google, and identical across all apps using the provider.
    See: https://developer.android.com/develop/ui/views/text-and-emoji/downloadable-fonts
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
